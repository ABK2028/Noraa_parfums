# Backend server
PORT=5000

# MySQL connection (Render Environment variables)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASS=your-mysql-password
# Optional alias if your provider gives DB_PASSWORD instead
# DB_PASSWORD=your-mysql-password
DB_NAME=your-database-name

# Optional pool tuning
DB_POOL_SIZE=10

# Alternative provider-style variables (Railway/Aiven-style)
# MYSQLHOST=your-mysql-host
# MYSQLPORT=3306
# MYSQLUSER=your-mysql-user
# MYSQLPASSWORD=your-mysql-password
# MYSQLDATABASE=your-database-name

# SSL toggles (set true if provider requires TLS)
# DB_SSL=true
# MYSQL_SSL=true
